{
    "title": "Salon and Spa Lead Finder Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "searchUrls": {
            "title": "Directory Search URLs",
            "type": "array",
            "description": "List of YellowPages directory search URLs for Salons or Spas.",
            "editor": "requestListSources",
            "default": [{"url": "https://www.yellowpages.com/search?search_terms=salon&geo_location_terms=Los+Angeles%2C+CA"}],
            "prefill": [{"url": "https://www.yellowpages.com/search?search_terms=salon&geo_location_terms=Los+Angeles%2C+CA"}]
        },
        "maxLeads": {
            "title": "Max Leads to Extract",
            "type": "integer",
            "description": "Maximum number of salon profiles to extract across all URLs.",
            "editor": "number",
            "minimum": 1,
            "maximum": 50000,
            "default": 500,
            "prefill": 500
        }
    },
    "required": ["searchUrls"]
}
